/// @desc Copy the input controller state onto this player instance.
function player_input()
{
    left        = global.leftKey;
    right       = global.rightKey;
    up          = global.upKey;
    down        = global.downKey;
    sprintKey   = global.sprintKey;   // Shift → sprint
    aimKey      = global.aimKey;      // RMB → ADS
    shootKey    = global.shootKey;
    shootPressed = global.shootPressed;
    reloadKey   = global.reloadKey;
    swapKey     = global.swapKey;
    num1Key     = global.num1Key;
    num2Key     = global.num2Key;
    num3Key     = global.num3Key;
    num4Key     = global.num4Key;
}
